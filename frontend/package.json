{
  "name": "silivri-kiosk",
  "productName": "T.C. Silivri Belediyesi Kiosk Yazılımı",
  "version": "122.0.6261",
  "description": "T.C. Silivri Belediyesi Kiosk Web Tarayıcısı",
  "main": "assets/js/main.js",
  "author": "T.C. Silivri Belediyesi Bilgi İşlem Müdürlüğü",
  "license": "Proprietary - T.C. Silivri Belediyesi",
  "private": true,
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64",
    "build:linux": "electron-builder --linux --x64"
  },
  "devDependencies": {
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "tr.bel.silivri.kiosk",
    "productName": "T.C. Silivri Belediyesi Kiosk Yazılımı",
    "executableName": "T.C. Silivri Belediyesi Kiosk Yazılımı",
    "copyright": "2026 © T.C. Silivri Belediyesi Bilgi İşlem Müdürlüğü",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/img/logo.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/img/logo.png",
      "category": "Utility"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
